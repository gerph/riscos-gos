/*************************************************** Gerph *********
 Function:      os_readvarval
 Description:   Read a variable value
 Parameters:    var-> the variable name to read
                buf-> the buffer to write to
                buflen = length of the buffer, or -1 to just read length
                context = the context for the call, or 0 for first call
                type = the variable type to read (3 to expand on return)
                sizep-> where to store the size that was read
                contextp-> where to store the context value
                typep-> where to store the type
 Returns:       error pointer, or NULL if ok
 ******************************************************************/
_kernel_oserror *os_readvarval(const char *var, char *buf, int buflen, uint32_t context, int type,
                               uint32_t *contextp, int *sizep, int *typep)
{
    _kernel_oserror *err;
    uintptr_t size = 0;
    err = _swix(OS_ReadVarVal, _INR(0,4)|_OUTR(2, 4), var, buf, buflen, context, type, &size, &context, &type);
    if (err)
    {
        if (err->errnum == ErrorNumber_VarCantFind)
        {
            /* End of enumeration */
            size = 0;
            type = -1;
            context = 0;
        }
        else if (err->errnum != ErrorNumber_BuffOverflow)
        {
            /* Other error type */
            size = 0;
            type = -1;
            context = 0;
        }
    }
    if (typep != NULL)
        *typep = type;
    if (contextp != NULL)
        *contextp = context;
    if (sizep != NULL)
        *sizep = size;
    return err;
}


/*************************************************** Gerph *********
 Function:      os_cli
 Description:   Run a CLI command
 Parameters:    cli-> the command line to run
 Returns:       pointer to error, or NULL if no error
 ******************************************************************/
_kernel_oserror *os_cli(const char *cli)
{
    _kernel_oserror *err;
    err = _swix(OS_CLI, _IN(0), cli);
    if (err)
        return err;
    return NULL;
}


/*************************************************** Gerph *********
 Function:      escape_check
 Description:   Check whether escape is pending
 Parameters:    none
 Returns:       true if pending, false if not
 ******************************************************************/
bool escape_check(void)
{
    _kernel_oserror *err;
    uint32_t flags = 0;
    err = _swix(OS_ReadEscapeState, _OUT(_FLAGS), &flags);
    if ((flags & _C) || err)
        return true;
    return false;
}

#define OSByte_AcknowledgeEscape 0x7E

/*************************************************** Gerph *********
 Function:      escape_acknowledge
 Description:   Acknowledge the escape conditions
 Parameters:    none
 Returns:       none
 ******************************************************************/
void escape_acknowledge(void)
{
    _swix(OS_Byte, _IN(0), OSByte_AcknowledgeEscape);
}


#ifdef SIMPLE_APP
/*************************************************** Gerph *********
 Function:      os_generateerror
 Description:   Raise an error to the environment
 Parameters:    err -> the error to raise
 Returns:       never
 ******************************************************************/
void os_generateerror(_kernel_oserror *err)
{
    _swi(OS_GenerateError, _IN(0), err);
    /* if it returns, that's BAD */
    os_exit();
}
