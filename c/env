void os_changeenvironment(int env, uint32_t in1, uint32_t in2, uint32_t in3, uint32_t *out1)
{
    dprintf("Change env %i : ", env);
    if (in1 == 0)
    { dprintf(" r1 = READ       "); }
    else
    { dprintf(" r1 = %x  ", in1); }
    if (in2 == 0)
    { dprintf(" r2 = READ       "); }
    else
    { dprintf(" r2 = %x  ", in2); }
    if (in3 == 0)
    { dprintf(" r3 = READ       "); }
    else
    { dprintf(" r3 = %x  ", in3); }


    dprintf("Return into %x\n", out1);

#ifdef SIMPLE_APP
    /* Do nothing */
#else
    if (out1)
    {
        _swix(OS_ChangeEnvironment, _INR(0, 3)|_OUTR(1,3), env, in1, in2, in3, out1, out1+1, out1+2);
    }
    else
    {
        _swix(OS_ChangeEnvironment, _INR(0, 3), env, in1, in2, in3);
    }
#endif
}


