/*************************************************** Gerph *********
 Function:      env_gos_apply
 Description:   Initialise our program environment handlers
 Parameters:    global-> out global workspace
                preserve = true if we are preserving parent, and false to just assert state
 Returns:       none
 ******************************************************************/
void env_gos_apply(globalws_t *global, bool preserve)
{
    dprintf("Env: Apply GOS environment\n");
    /* All environment handlers should preserved */
    /* All environment handlers should be set; mostly to the defaults */

    os_changeenvironment(MemoryLimit,
                         ENV_READ, ENV_READ, ENV_READ,
                         !preserve ? NULL : &global->parent_handlers.memory_limit);

    os_changeenvironment(UndefinedHandler,
                         ENV_READ, ENV_READ, ENV_READ,
                         !preserve ? NULL : &global->parent_handlers.abort_undef_handler);

    os_changeenvironment(PrefetchAbortHandler,
                         ENV_READ, ENV_READ, ENV_READ,
                         !preserve ? NULL : &global->parent_handlers.abort_prefetch_handler);

    os_changeenvironment(DataAbortHandler,
                         ENV_READ, ENV_READ, ENV_READ,
                         !preserve ? NULL : &global->parent_handlers.abort_data_handler);

    os_changeenvironment(AddressExceptionHandler,
                         ENV_READ, ENV_READ, ENV_READ,
                         !preserve ? NULL : &global->parent_handlers.abort_address_handler);

    os_changeenvironment(OtherExceptionHandler,
                         ENV_READ, ENV_READ, ENV_READ,
                         !preserve ? NULL : &global->parent_handlers.abort_exception_handler);

    os_changeenvironment(ErrorHandler,
                         (uint32_t)&_env_error, (uint32_t)&global->error_buffer.err, (uint32_t)&global->error_buffer,
                         !preserve ? NULL : &global->parent_handlers.error_handler);

    os_changeenvironment(CallBackHandler,
                         ENV_READ, ENV_READ, ENV_READ,
                         !preserve ? NULL : &global->parent_handlers.callback_handler);

    os_changeenvironment(EscapeHandler,
                         (uint32_t)&_env_escape, ENV_READ, ENV_READ,
                         !preserve ? NULL : &global->parent_handlers.escape_handler);

    os_changeenvironment(EventHandler,
                         ENV_READ, ENV_READ, ENV_READ,
                         !preserve ? NULL : &global->parent_handlers.event_handler);

    os_changeenvironment(ExitHandler,
                         (uint32_t)&_env_exit, ENV_READ, ENV_READ,
                         !preserve ? NULL : &global->parent_handlers.exit_handler);

    os_changeenvironment(UpCallHandler,
                         ENV_READ, ENV_READ, ENV_READ,
                         !preserve ? NULL : &global->parent_handlers.upcall_handler);
}

/*************************************************** Gerph *********
 Function:      env_gos_restore
 Description:   Restore parent program environment handlers
 Parameters:    global-> out global workspace
 Returns:       none
 ******************************************************************/
void env_gos_restore(globalws_t *global)
{
    /* All environment handlers should restored from the parent */
    dprintf("Env: Restore parent environment\n");
    os_changeenvironment(MemoryLimit,
                         global->parent_handlers.memory_limit,
                         global->parent_handlers.memory_unused_r2,
                         global->parent_handlers.memory_unused_r3,
                         NULL);

    os_changeenvironment(UndefinedHandler,
                         global->parent_handlers.abort_undef_handler,
                         global->parent_handlers.abort_undef_unused_r2,
                         global->parent_handlers.abort_undef_unused_r3,
                         NULL);

    os_changeenvironment(PrefetchAbortHandler,
                         global->parent_handlers.abort_prefetch_handler,
                         global->parent_handlers.abort_prefetch_unused_r2,
                         global->parent_handlers.abort_prefetch_unused_r3,
                         NULL);

    os_changeenvironment(DataAbortHandler,
                         global->parent_handlers.abort_data_handler,
                         global->parent_handlers.abort_data_unused_r2,
                         global->parent_handlers.abort_data_unused_r3,
                         NULL);

    os_changeenvironment(AddressExceptionHandler,
                         global->parent_handlers.abort_address_handler,
                         global->parent_handlers.abort_address_unused_r2,
                         global->parent_handlers.abort_address_unused_r3,
                         NULL);

    os_changeenvironment(OtherExceptionHandler,
                         global->parent_handlers.abort_exception_handler,
                         global->parent_handlers.abort_exception_unused_r2,
                         global->parent_handlers.abort_exception_unused_r3,
                         NULL);

    os_changeenvironment(ErrorHandler,
                         global->parent_handlers.error_handler,
                         global->parent_handlers.error_workspace,
                         (intptr_t)global->parent_handlers.error_buffer,
                         NULL);

    os_changeenvironment(CallBackHandler,
                         global->parent_handlers.callback_handler,
                         global->parent_handlers.callback_workspace,
                         global->parent_handlers.callback_registers,
                         NULL);

    os_changeenvironment(EscapeHandler,
                         global->parent_handlers.escape_handler,
                         global->parent_handlers.escape_workspace,
                         global->parent_handlers.escape_unused_r3,
                         NULL);

    os_changeenvironment(EventHandler,
                         global->parent_handlers.event_handler,
                         global->parent_handlers.event_workspace,
                         global->parent_handlers.event_unused_r3,
                         NULL);

    os_changeenvironment(ExitHandler,
                         global->parent_handlers.exit_handler,
                         global->parent_handlers.exit_workspace,
                         global->parent_handlers.exit_unused_r3,
                         NULL);

    os_changeenvironment(UpCallHandler,
                         global->parent_handlers.upcall_handler,
                         global->parent_handlers.upcall_workspace,
                         global->parent_handlers.upcall_unused_r3,
                         NULL);
}



