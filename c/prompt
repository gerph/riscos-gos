/* Defines for the strings we use */
#define PROMPT_DEFAULT "*"
#define PROMPT_VAR "CLI$Prompt"

#define SUPERVISOR_TITLE "Supervisor"

#define ERROR_PREFIX "Error: "
#define ERROR_SUFFIX " (Error number &"
#define ERROR_TRAILER ")"

#define ESCAPE "Escape"


#define hexchar "0123456789ABCDEF"
void os_writehex(uint32_t hex)
{
    char buffer[9];
    char *p = buffer;
    uint32_t v;

#define WRITEHEX(shift) \
    v = (hex>>shift) & 15; \
    if (p!=buffer || v != 0) \
        *p++ = hexchar[v];

    WRITEHEX(28);
    WRITEHEX(24);
    WRITEHEX(20);
    WRITEHEX(16);
    WRITEHEX(12);
    WRITEHEX(8);
    WRITEHEX(4);
    WRITEHEX(0);
    if (p == buffer)
        *p++ = '0';

    os_writen(buffer, p-buffer);
}

/*************************************************** Gerph *********
 Function:      gos_workspace_size
 Description:   Read the size of the global workspace we need
 Parameters:    none
 Returns:       size of the global workspace we need
 ******************************************************************/
int gos_workspace_size(void)
{
    return sizeof(globalws_t);
}


/*************************************************** Gerph *********
 Function:      print_command_prompt
 Description:   Write out the command prompt
 Parameters:    global-> our global workspace
 Returns:       none
 ******************************************************************/
void print_command_prompt(globalws_t *global)
{
    _kernel_oserror *err;
    int size;
    const char *prompt;

    dprintf("print_command_prompt: global workspace = %p\n", global);
    dprintf("print_command_prompt: cli workspace = %p\n", global->cli);

    err = os_readvarval(PROMPT_VAR, global->cli, global->clisize, 0, VarType_String,
                        NULL, &size, NULL);
    if (err)
    {
        dprintf("Error: %s\n", err->errmess);
        prompt = PROMPT_DEFAULT;
        size = strlen(prompt);
    }
    else
    {
        prompt = global->cli;
    }

    os_writen(prompt, size);
}


/*************************************************** Gerph *********
 Function:      print_error
 Description:   Print out an error message
 Parameters:    global-> our global workspace
                err-> the error message to print
 Returns:       none
 ******************************************************************/
void print_error(globalws_t *global, _kernel_oserror *err)
{
    /* If there is an error we call OS_GenerateError (or use OS_CLI directly without X) */
    os_write0(ERROR_PREFIX);
    os_write0(err->errmess);
    os_write0(ERROR_SUFFIX);
    os_writehex(err->errnum);
    os_write0(ERROR_TRAILER);
    os_newline();
}

/*************************************************** Gerph *********
 Function:      escape
 Description:   Escape reporting
 Parameters:    none
 Returns:       none
 ******************************************************************/
void escape(void)
{
    escape_acknowledge();
    os_newline();
    os_write0(ESCAPE);
    os_newline();
}

/*************************************************** Gerph *********
 Function:      run_prompt
 Description:   Runs the command prompt-execution loop
 Parameters:    global-> the global workspace
 Returns:       error block if we're raising an error, or NULL if we're just OS_Exiting
 ******************************************************************/
_kernel_oserror *run_prompt(globalws_t *global)
{
    _kernel_oserror *err = NULL;
    bool still_running = true;

    env_cli_restore(global);

    while (still_running)
    {
        global->in_prompt = true;

        if (escape_check())
        {
            escape();
            continue;
        }

        /* We output the CLI$Prompt string. OR '*' if none was set */
        print_command_prompt(global);

        /* We read a line of input from the user */
        err = os_readline(global->cli, global->clisize);
        if (err)
        {
            if (err->errnum == 17)
            {
                /* If it was just an escape, we keep going around the loop */
                escape();
                continue;
            }
            /* Other errors are fatal */
            print_error(global, err);
            break;
        }
        dprintf("Read line: >%s<\n", global->cli);

        /* Check whether the input string was '*' (any number of times) space (any number of times) 'Quit' (in any case),
           and if so, we exit the loop */
        {
            const char *cli = global->cli;
            while (*cli == '*' || *cli == ' ')
                cli++;
            if ( ((cli[0] | 32) == 'q') &&
                 ((cli[1] | 32) == 'u') &&
                 ((cli[2] | 32) == 'i') &&
                 ((cli[3] | 32) == 't') &&
                 (cli[4] == '\0'))
            {
                /* They explicitly said Quit */
                dprintf("*QUIT used; return to parent\n");
                err = NULL;
                break;
            }
        }

        global->in_prompt = false;

        /* We set up a environment that will report crashes, exits and errors and then return to the input loop */
        env_cli_apply(global);

        /* Invoke OS_CLI on the line input */
#ifdef SIMPLE_APP
        system(global->cli);
#else
        err = os_cli(global->cli);
        if (err)
        {
            os_generateerror(err);
        }
#endif

        /* Restore the error handlers to the outer *GOS system */
        env_cli_restore(global);
    }

    /* Restore error handlers for the parent system */
    env_gos_restore(global);

    /* If err is set, return it so that the assembly can raise the error */
    return err;
}


/*************************************************** Gerph *********
 Function:      start_supervisor
 Description:   Start the command line supervisor
 Parameters:    global-> our global workspace
 Returns:       pointer to error if we OS_GenerateError, or NULL for OS_Exit
 ******************************************************************/
_kernel_oserror *start_supervisor(globalws_t *global)
{
    os_write0(SUPERVISOR_TITLE);
    os_newline();
    os_newline();

    /* We need to set up environment for the *GOS system so that crashes, exits, and errors are handled. */
    /* We need upcall handler set because otherwise switching contexts will break */
    env_gos_apply(global, true);

    return run_prompt(global);
}



/*************************************************** Gerph *********
 Function:      env_exit
 Description:   Exit handler code
 Parameters:    global-> our global workspace
 Returns:       error pointer if we are to raise an error (OS_GenerateError), or NULL to exit (OS_Exit)
                On return the environment should have been restored.
 ******************************************************************/
_kernel_oserror *env_exit(globalws_t *global)
{
    _kernel_oserror *err;

    /* They called OS_Exit, so just go back to the prompt (unless they were /at/ the prompt, in which case exit) */
    dprintf("GOS: Exit handler (%s)\n", global->in_prompt ? "in prompt" : "outside prompt");
    if (global->in_prompt)
    {
        env_gos_restore(global);
        /* We were in the prompt so we restore environment and exit */
        err = NULL; /* Just OS_Exit */
    }
    else
    {
        err = run_prompt(global);
    }
    /* Return from this environment exit handler, frees all our workspace and calls OS_Exit */
    return err;
}


/*************************************************** Gerph *********
 Function:      env_error
 Description:   Error handler code
 Parameters:    global-> our global workspace
 Returns:       error pointer if we are to raise an error (OS_GenerateError), or NULL to exit (OS_Exit)
                On return the environment should have been restored.
 ******************************************************************/
_kernel_oserror *env_error(globalws_t *global)
{
    _kernel_oserror *err = &global->error_buffer.err;
    dprintf("GOS: Error handler\n");

    print_error(global, err);

    /* And return to the command line input */
    err = run_prompt(global);

    /* Return from this environment exit handler, frees all our workspace and calls OS_Exit */
    return err;
}


