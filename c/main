 * Purpose:     GOS command line tool
 * Author:      Gerph
 ******************************************************************/

#include <stdlib.h>
#include <stdio.h>
#include <stdbool.h>
#include <signal.h>
#include <string.h>

#include "global.h"
#include "os.h"
#include "env.h"
#include "prompt.h"

#include "VersionNum"

#define DEBUG

#ifdef DEBUG
#define dprintf if (1) printf
#else
#define dprintf if (0) printf
#endif







/*************************************************** Gerph *********
 Function:      env_exit
 Description:   Exit handler code
 Parameters:    global-> our global workspace
 Returns:       error pointer if we are to raise an error (OS_GenerateError), or NULL to exit (OS_Exit)
                On return the environment should have been restored.
 ******************************************************************/
_kernel_oserror *env_exit(globalws_t *global)
{
    _kernel_oserror *err;

    /* They called OS_Exit, so just go back to the prompt (unless they were /at/ the prompt, in which case exit) */
    dprintf("GOS: Exit handler (%s)", global->in_prompt ? "in prompt" : "outside prompt");
    if (global->in_prompt)
    {
        env_gos_restore(global);
        /* We were in the prompt so we restore environment and exit */
        err = NULL; /* Just OS_Exit */
    }
    else
    {
        err = run_prompt(global);
    }
    /* Return from this environment exit handler, frees all our workspace and calls OS_Exit */
    return err;
}


/*************************************************** Gerph *********
 Function:      env_error
 Description:   Error handler code
 Parameters:    global-> our global workspace
 Returns:       error pointer if we are to raise an error (OS_GenerateError), or NULL to exit (OS_Exit)
                On return the environment should have been restored.
 ******************************************************************/
_kernel_oserror *env_error(globalws_t *global, _kernel_oserror *err)
{
    dprintf("GOS: Error handler");

    print_error(global, err);

    /* And return to the command line input */
    err = run_prompt(global);

    /* Return from this environment exit handler, frees all our workspace and calls OS_Exit */
    return err;
}


/*************************************************** Gerph *********
 Function:      env_escape
 Description:   Escape handler code
 Parameters:    global-> our global workspace
 Returns:       none (returns back to the application unless you do something else)
 ******************************************************************/
void env_escape(globalws_t *global)
{
    /* Nothing to do here (in the default Escape handler this is MOV pc,lr) */
    dprintf("GOS: Escape handler");
}



/*************************************************** Gerph *********
 Function:      cmd_gos
 Description:   Run the *GOS implementation, supplied only with workspace
 Parameters:    global-> our global workspace
 Returns:       pointer to error, if we failed and need to return to the caller with it, or NULL if just exiting
 ******************************************************************/
_kernel_oserror *cmd_gos(globalws_t *global)
{
    /* Stack setup is in assembly before we reach here - we should have a couple of kilobytes,
       because we need command line input which is a few K. */

    /* FIXME: We may need to set up the CAO - this should be done by the module entry */

    return start_supervisor(global);
}



int main(int argc, char *argv[])
{
    _kernel_oserror *err;

    /* We need some global workspace set up */
    globalws_t global;

    signal(SIGINT, SIG_IGN);

#define CLI_SIZE (1024)
    /* FIXME: Read the CLI size for this OS */
    global.cli = malloc(CLI_SIZE);
    global.clisize = CLI_SIZE;
    err = cmd_gos(&global);
    /* Free the global workspace */
    /* raise any errors */
    if (err)
    {
        printf("Raise error to parent environment by calling OS_GenerateError: %s\n", err->errmess);
        exit(EXIT_FAILURE);
    }

    exit(EXIT_SUCCESS);
}
