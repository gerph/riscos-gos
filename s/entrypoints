; Entrypoints for the *GOS command

        AREA    |C$$code|, CODE, READONLY

        GET     hdr.modhand
        GET     hdr.swis
        GET     hdr.printmacros
        GET     hdr.procapcs
        GET     hdr.envnumbers

STACKSIZE       *   1024

        IMPORT  gos_workspace_size
        IMPORT  start_supervisor
        IMPORT  env_error
        IMPORT  env_exit
        IMPORT  env_escape

        EXPORT  enter_gos
        EXPORT  _env_error
        EXPORT  _env_escape
        EXPORT  _env_exit


enter_gos APCSEntry "r4-r9"

        ; Allocate some memory for the USR mode stack.
        ; Allocate our global workspace.
        BL      gos_workspace_size                          ; read the workspace size the C needs
        MOV     r4, r0

            PrintMessage "get_workspace_size: "
            PrintInteger r4
            SWI     OS_NewLine

        BL      get_cli_size
        MOV     r5, r0

            PrintMessage "get_cli_size: "
            PrintInteger r5
            SWI     OS_NewLine

        ADD     r3, r4, #STACKSIZE
        ADD     r3, r3, r5

            PrintMessage "total workspace: "
            PrintInteger r3
            SWI     OS_NewLine

        XSWI    XOS_Module, #ModHandReason_Claim
        BVS     %FT90
        ; r2 = our workspace ptr, with stack above it (r3 bytes above)
        ; r5 contains the size of the CLI buffer
        ; r4 contains the global workspace size

            PrintMessage "global workspace: "
            PrintHex r2
            SWI     OS_NewLine

        ; Drop to USR mode.
        MRS     r0, CPSR
        BIC     r0, r0, #0x1F                               ; enter user mode
        MSR     CPSR_cxsf, r0

        ; Set the stack pointer.
        ADD     sp, r2, r3                                  ; sp-> end of the workspace
        SUB     sl, sp, #STACKSIZE                          ; stack limit = end - stack size
        MOV     fp, #0                                      ; clear the frame pointer

            MOV     r0, sp
            PrintMessage "stack pointer: "
            PrintHex r0
            SWI     OS_NewLine
            PrintMessage "stack limit: "
            PrintHex sl
            SWI     OS_NewLine

        ; Initialise the global workspace
        ADD     r6, r2, r4                                  ; r6-> CLI buffer
        STR     r6, [r2, #0]                                ; global->cli = CLI buffer
        STR     r5, [r2, #4]                                ; global->clisize = CLI size
        STR     sp, [r2, #8]                                ; global->stacktop = stack top

        ; Start execution at `start_supervisor`, passing workspace
        MOV     r0, r2
        BL      start_supervisor

; Common exit when supervisor returns (from error or exit handlers)
handle_exit
        CMP     r0, #0

        ; if we returned with a error, call OS_GenerateError
        ; if no error, call OS_Exit
        SWIVS   OS_GenerateError
        SWI     OS_Exit

        ; We never reach here.

90
        APCSExit



get_cli_size APCSEntry
        XSWI    OS_ChangeEnvironment, #CommandLineArea, 0, 0, 0
        MOVVC   r0, r2
        BVC     %FT90

; Not a system that understands the OS_ChangeEnvironment for the CLI size; let's work it out.
OSByte_ReadKeyboard * 0x81
; The following system types have 1024 byte CLIs:
;     &A8 RISC OS 4.0x
;     &A9 RISC OS 4.3x
;     &AA RISC OS 5.xx
;     &AE RISC OS Pyromaniac
; Everyone else is 256.
        XSWI    OS_Byte, #OSByte_ReadKeyboard, #0, #255
        SUB     r1, r1, #&A8
        CMP     r1, #&AE-&A8
        MOVHI   r0, #256                                    ; everyone else is 256
        MOVLS   r0, #1024

90
        APCSExit





;void _env_error(_kernel_oserror *err)
; => R0 = global workspace pointer
;    USR mode
_env_error SIGNATURE
        MOV     fp, #0
        LDR     sp, [r0, #8]                                ; restore stack to the top
        SUB     sl, sp, #STACKSIZE
        BL      env_error                                   ; The C handler
        B       handle_exit


;void _env_exit(_kernel_oserror *err)
; => R12 = global workspace pointer
;    USR mode
_env_exit SIGNATURE
        MOV     fp, #0
        LDR     sp, [r12, #8]                               ; restore stack to the top
        SUB     sl, sp, #STACKSIZE
        MOV     r0, r12
        BL      env_exit                                    ; The C handler
        B       handle_exit


;void _env_escape(_kernel_oserror *err)
; => R12 = global workspace pointer
;   SVC mode
_env_escape SIGNATURE
        Entry   "r1-r3, r10-r12"
        MOV     fp, #0
        MOV     r0, r12
        BL      env_escape
        EXIT

        EXPORT os_generateerror
os_generateerror SIGNATURE
        SWI     OS_GenerateError
        SWI     OS_Exit

        END
